# Caddy-Konfiguration für den Hetzner-Server.
# Platzhalter <domain> durch die echte Domain ersetzen.
# Caddy holt/erneuert TLS-Zertifikate automatisch (Let's Encrypt).
#
# basicauth-Hash erzeugen:  caddy hash-password
# (Beta ist passwortgeschützt, weil dort BSG_DEV=1 läuft.)

# --- BETA: passwortgeschützt, Reverse-Proxy auf den Beta-Node (:8081) ---
beta.<domain> {
	encode gzip
	basicauth {
		# Benutzername  <bcrypt-hash>
		beta JDJhJDE0J...ERSETZEN...
	}
	reverse_proxy localhost:8081
}

# --- RELEASE/PROD: öffentlich, Reverse-Proxy auf den Prod-Node (:8080) ---
<domain>, www.<domain> {
	encode gzip
	reverse_proxy localhost:8080
}
