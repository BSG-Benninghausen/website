---
import Base from "../layouts/Base.astro";
---
<Base pageTitle="Offline" noindex={true}>
  <section class="hero" style="min-height:70vh;display:flex;align-items:center">
    <img class="hero__pattern" src="assets/img/hero-pattern.svg" alt="" aria-hidden="true">
    <span class="hero__glow hero__glow--a" aria-hidden="true"></span>
    <img class="hero__dragon" src="assets/img/drache-light.png" alt="" aria-hidden="true">
    <div class="wrap center" style="max-width:620px">
      <span class="eyebrow eyebrow--invert" style="justify-content:center">Offline</span>
      <h1 style="font-size:clamp(2.4rem,8vw,4.5rem);color:#fff;margin:14px 0 12px">Keine Verbindung</h1>
      <p class="hero__lead" style="margin-inline:auto">Diese Seite ist offline gerade nicht verfügbar. Bereits besuchte Seiten funktionieren weiterhin – probiere es sonst erneut, sobald du wieder online bist.</p>
      <div class="hero__cta" style="justify-content:center">
        <button type="button" class="btn btn--gold btn--lg" onclick="location.reload()">Erneut versuchen</button>
        <a href="index.html" class="btn btn--ghost btn--lg">Zur Startseite</a>
      </div>
    </div>
  </section>
</Base>
