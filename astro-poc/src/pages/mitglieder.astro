---
import Base from "../layouts/Base.astro";
---
<Base pageTitle="Mitglieder & Benutzer" noindex={true}>
  <section class="page-hero">
    <img class="page-hero__pattern" src="assets/img/hero-pattern.svg" alt="" aria-hidden="true">
    <img class="page-hero__dragon" src="assets/img/drache-light.png" alt="" aria-hidden="true">
    <div class="wrap page-hero__inner">
      <p class="crumbs"><a href="index.html">Start</a> · <a href="konto.html">Mein Konto</a> · Mitglieder &amp; Benutzer</p>
      <span class="eyebrow eyebrow--invert">Verwaltung</span>
      <h1>Mitglieder &amp; Benutzer</h1>
      <p>Login-Konten und ihre Mitgliedschaften in einer Liste. Jedes Mitglied gehört zu einem Benutzer (Haushalt). Details öffnen sich seitlich.</p>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <p id="vw-loading" class="center" style="color:var(--text-soft)">Lade Verwaltung …</p>
      <div id="vw-main" hidden>
        <div id="vw-toggle" class="vw-toggle" role="group" aria-label="Ansicht wählen"></div>
        <div id="vw-meta" class="billing-summary" style="margin:14px 0 18px" hidden></div>
        <div id="vw-status" class="form-status" role="status" aria-live="polite"></div>
        <div id="vw-list" class="adm-users"></div>
      </div>
    </div>
  </section>

  <div id="vw-scrim" class="drawer__scrim" hidden></div>
  <aside id="vw-drawer" class="drawer" aria-hidden="true" aria-label="Details">
    <div class="drawer__head">
      <span class="eyebrow">Details</span>
      <button type="button" class="drawer__close" data-drawer-close aria-label="Schließen">&times;</button>
    </div>
    <div id="vw-drawer-body" class="drawer__body"></div>
  </aside>

  <Fragment slot="scripts">
    <script is:inline src="assets/js/verwaltung.js"></script>
  </Fragment>
</Base>
