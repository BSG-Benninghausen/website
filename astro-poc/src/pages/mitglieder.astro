---
import Base from "../layouts/Base.astro";
---
<Base pageTitle="Mitglieder">
  <section class="page-hero">
    <img class="page-hero__pattern" src="assets/img/hero-pattern.svg" alt="" aria-hidden="true">
    <img class="page-hero__dragon" src="assets/img/drache-light.png" alt="" aria-hidden="true">
    <div class="wrap page-hero__inner">
      <p class="crumbs"><a href="index.html">Start</a> · <a href="konto.html">Mein Konto</a> · Mitglieder</p>
      <span class="eyebrow eyebrow--invert">Intern</span>
      <h1>Mitgliederübersicht</h1>
      <p>Alle angemeldeten Mitglieder im Überblick – nur lesend.</p>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <p id="members-loading" class="center" style="color:var(--text-soft)">Lade Mitglieder …</p>
      <div id="members" hidden>
        <div id="members-meta" class="billing-summary" style="margin-bottom:18px"></div>
        <div class="card" style="overflow-x:auto">
          <table class="data-table" id="members-table">
            <thead></thead>
            <tbody></tbody>
          </table>
        </div>
        <div id="households" hidden>
          <h2 style="font-size:1.2rem;margin:28px 0 12px">Beiträge je Haushalt</h2>
          <div class="card" style="overflow-x:auto">
            <table class="data-table" id="households-table">
              <thead><tr><th>Haushalt</th><th>E-Mail</th><th>IBAN</th><th>Mitglieder</th><th>Beitrag/Monat</th></tr></thead>
              <tbody></tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Fragment slot="scripts">
    <script is:inline src="assets/js/sponsors.js"></script>
    <script is:inline src="assets/js/mitglieder.js"></script>
  </Fragment>
</Base>
