---
import Base from "../layouts/Base.astro";
---
<Base pageTitle="Redaktion">
  <section class="page-hero">
    <img class="page-hero__pattern" src="assets/img/hero-pattern.svg" alt="" aria-hidden="true">
    <span class="page-hero__dragon" aria-hidden="true"></span>
    <div class="wrap page-hero__inner">
      <p class="crumbs"><a href="index.html">Start</a> · <a href="konto.html">Mein Konto</a> · Redaktion</p>
      <span class="eyebrow eyebrow--invert">Redaktion</span>
      <h1>Inhalte pflegen</h1>
      <p>News, Termine, Trainingszeiten und Startseiten-Texte – je nach Berechtigung. Änderungen erscheinen sofort auf der Website. (Vorstand/Trainer werden über die Rollen im Admin-Bereich gepflegt.)</p>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <p id="red-loading" class="center" style="color:var(--text-soft)">Lade Redaktion …</p>

      <div id="red" hidden>
        <div id="red-status" class="form-status" role="status" aria-live="polite"></div>

        <div id="news-section" class="card" style="margin-bottom:24px" hidden>
          <span class="eyebrow">Aktuelles</span>
          <h2 style="font-size:1.3rem;margin:6px 0 16px">Newsmeldungen</h2>
          <div id="news-list" class="adm-roles"></div>
          <form id="news-form" class="sub-form" novalidate>
            <input type="hidden" name="id">
            <h3 id="news-form-title" style="font-size:1.1rem;margin-bottom:14px">Neue Meldung</h3>
            <div class="field-row">
              <div class="field">
                <label for="n-title">Titel <span class="req">*</span></label>
                <input id="n-title" name="title" type="text">
                <p class="field__error"></p>
              </div>
              <div class="field">
                <label for="n-date">Datum <span class="req">*</span></label>
                <input id="n-date" name="date" type="date">
                <p class="field__error"></p>
              </div>
            </div>
            <div class="field">
              <label for="n-tag">Kategorie</label>
              <input id="n-tag" name="tag" type="text" placeholder="z. B. Turnier, Verein, Wettkampf">
            </div>
            <div class="field">
              <label for="n-excerpt">Anriss / Kurztext <span class="req">*</span></label>
              <textarea id="n-excerpt" name="excerpt" placeholder="Kurze Zusammenfassung für die Übersicht"></textarea>
              <p class="field__error"></p>
            </div>
            <div class="field">
              <label for="n-body">Volltext</label>
              <textarea id="n-body" name="body" placeholder="Ausführlicher Text"></textarea>
            </div>
            <div class="field" data-news-image-field>
              <label for="n-image">Bild <span style="font-weight:400;color:var(--text-soft)">(optional)</span></label>
              <div class="photo-input">
                <img id="n-image-preview" class="photo-input__preview photo-input__preview--wide" alt="" hidden>
                <div class="photo-input__ph photo-input__ph--wide" id="n-image-ph" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="5" width="18" height="14" rx="2"/><circle cx="9" cy="11" r="2"/><path d="M21 17l-5-5-4 4-2-2-4 4"/></svg>
                </div>
                <div>
                  <input id="n-image" name="image" type="file" accept="image/*">
                  <p style="color:var(--text-soft);font-size:.82rem;margin-top:6px">JPG/PNG, wird automatisch verkleinert. Querformat empfohlen.</p>
                  <button type="button" id="n-image-clear" class="btn btn--outline btn--sm" style="margin-top:8px" hidden>Bild entfernen</button>
                </div>
              </div>
              <p class="field__error"></p>
            </div>
            <div style="display:flex;gap:12px;flex-wrap:wrap">
              <button type="submit" class="btn btn--primary"><span class="spinner" aria-hidden="true"></span>Veröffentlichen</button>
              <button type="button" id="news-reset" class="btn btn--outline" hidden>Abbrechen</button>
            </div>
            <div class="form-status" role="status" aria-live="polite"></div>
          </form>
        </div>

        <div id="events-section" class="card" hidden>
          <span class="eyebrow">Kalender</span>
          <h2 style="font-size:1.3rem;margin:6px 0 16px">Termine</h2>
          <div id="events-list" class="adm-roles"></div>
          <form id="event-form" class="sub-form" novalidate>
            <input type="hidden" name="id">
            <h3 id="event-form-title" style="font-size:1.1rem;margin-bottom:14px">Neuer Termin</h3>
            <div class="field-row">
              <div class="field">
                <label for="e-title">Titel <span class="req">*</span></label>
                <input id="e-title" name="title" type="text">
                <p class="field__error"></p>
              </div>
              <div class="field">
                <label for="e-date">Datum <span class="req">*</span></label>
                <input id="e-date" name="date" type="date">
                <p class="field__error"></p>
              </div>
            </div>
            <div class="field-row">
              <div class="field">
                <label for="e-time">Uhrzeit</label>
                <input id="e-time" name="time" type="text" placeholder="z. B. 17:00 – 19:45 Uhr">
              </div>
              <div class="field">
                <label for="e-type">Art</label>
                <select id="e-type" name="type">
                  <option>Training</option>
                  <option>Turnier</option>
                  <option>Meisterschaft</option>
                  <option>Prüfung</option>
                  <option>Event</option>
                </select>
              </div>
            </div>
            <div class="field">
              <label for="e-location">Ort</label>
              <input id="e-location" name="location" type="text" placeholder="z. B. Sporthalle Musterstadt">
            </div>
            <div class="field-row">
              <div class="field">
                <label for="e-fee">Gebühr (€)</label>
                <input id="e-fee" name="fee" type="number" min="0" step="0.01" inputmode="decimal" placeholder="0">
                <p class="field__error"></p>
              </div>
              <div class="field">
                <label for="e-own">Eigenanteil (€)</label>
                <input id="e-own" name="ownShare" type="number" min="0" step="0.01" inputmode="decimal" placeholder="0">
                <p class="field__error"></p>
              </div>
            </div>
            <p class="muted-note" style="margin:-6px 0 4px">Die Differenz (Gebühr − Eigenanteil) trägt der Verein.</p>
            <div class="field" id="event-ageclasses-field" hidden>
              <label>Altersklassen <span class="muted-note">(leer = offen für alle)</span></label>
              <fieldset id="event-ageclasses" class="perm-grid" style="border:0;padding:0;margin:0"></fieldset>
            </div>
            <div class="field-row" id="event-organizer-field" hidden>
              <div class="field">
                <label for="e-org-name">Veranstalter</label>
                <input id="e-org-name" name="organizerName" type="text" placeholder="z. B. SV Musterstadt">
              </div>
              <div class="field">
                <label for="e-org-iban">Veranstalter-IBAN <span class="muted-note">(für die Überweisung der Teilnahmegebühren)</span></label>
                <input id="e-org-iban" name="organizerIban" type="text" autocomplete="off" placeholder="DE…">
                <p class="field__error"></p>
              </div>
            </div>
            <div style="display:flex;gap:12px;flex-wrap:wrap">
              <button type="submit" class="btn btn--primary"><span class="spinner" aria-hidden="true"></span>Speichern</button>
              <button type="button" id="event-reset" class="btn btn--outline" hidden>Abbrechen</button>
            </div>
            <div class="form-status" role="status" aria-live="polite"></div>
          </form>
        </div>

        <div id="registrations-section" class="card" style="margin-top:24px" hidden>
          <span class="eyebrow">Wettkampf</span>
          <h2 style="font-size:1.3rem;margin:6px 0 16px">Turnier-Anmeldungen</h2>
          <div id="registrations-list" class="adm-roles"></div>
        </div>

        <div id="payouts-section" class="card" style="margin-top:24px" hidden>
          <span class="eyebrow">Finanzen</span>
          <h2 style="font-size:1.3rem;margin:6px 0 16px">Veranlasste Überweisungen</h2>
          <div id="payouts-list" class="adm-roles"></div>
        </div>

        <div id="training-section" class="card" style="margin-top:24px" hidden>
          <span class="eyebrow">Training</span>
          <h2 style="font-size:1.3rem;margin:6px 0 16px">Trainingszeiten</h2>
          <div id="training-list" class="adm-roles"></div>
          <form id="training-form" class="sub-form" novalidate>
            <input type="hidden" name="id">
            <h3 id="training-form-title" style="font-size:1.1rem;margin-bottom:14px">Neue Trainingszeit</h3>
            <div class="field-row">
              <div class="field">
                <label for="t-title">Titel / Gruppe <span class="req">*</span></label>
                <input id="t-title" name="title" type="text" placeholder="z. B. Kinder">
                <p class="field__error"></p>
              </div>
              <div class="field">
                <label for="t-age">Altersgruppe</label>
                <input id="t-age" name="ageGroup" type="text" placeholder="z. B. ab 5 Jahre">
              </div>
            </div>
            <div class="field-row">
              <div class="field">
                <label for="t-start">Beginn <span class="req">*</span></label>
                <input id="t-start" name="start" type="text" placeholder="z. B. 17:00">
                <p class="field__error"></p>
              </div>
              <div class="field">
                <label for="t-end">Ende</label>
                <input id="t-end" name="end" type="text" placeholder="z. B. 18:00">
              </div>
            </div>
            <div class="field">
              <label for="t-desc">Beschreibung</label>
              <textarea id="t-desc" name="description" placeholder="Kurzbeschreibung der Gruppe"></textarea>
            </div>
            <div style="display:flex;gap:12px;flex-wrap:wrap">
              <button type="submit" class="btn btn--primary"><span class="spinner" aria-hidden="true"></span>Speichern</button>
              <button type="button" id="training-reset" class="btn btn--outline" hidden>Abbrechen</button>
            </div>
            <div class="form-status" role="status" aria-live="polite"></div>
          </form>
        </div>

        <div id="site-section" class="card" style="margin-top:24px" hidden>
          <span class="eyebrow">Startseite</span>
          <h2 style="font-size:1.3rem;margin:6px 0 6px">Startseiten-Texte</h2>
          <p class="muted-note" style="margin-bottom:16px">Diese Texte erscheinen auf der Startseite. Leere Felder verwenden die Standardtexte.</p>
          <form id="site-form" class="sub-form" novalidate>
            <div id="site-fields"></div>
            <div style="display:flex;gap:12px;flex-wrap:wrap">
              <button type="submit" class="btn btn--primary"><span class="spinner" aria-hidden="true"></span>Texte speichern</button>
            </div>
            <div class="form-status" role="status" aria-live="polite"></div>
          </form>
        </div>

        <div id="sponsors-section" class="card" style="margin-top:24px" hidden>
          <span class="eyebrow">Partner</span>
          <h2 style="font-size:1.3rem;margin:6px 0 6px">Sponsoren</h2>
          <p class="muted-note" style="margin-bottom:16px">Logos &amp; Partner des Vereins. Über die Einstellungen unten bestimmst du, ob und wie sie auf der Website erscheinen.</p>

          <form id="sponsors-config-form" class="sub-form" novalidate style="margin-bottom:24px">
            <h3 style="font-size:1.1rem;margin-bottom:14px">Anzeige-Einstellungen</h3>
            <label class="perm-item"><input type="checkbox" name="enabled"><span>Sponsoren auf der Website anzeigen</span></label>
            <div class="field-row">
              <div class="field">
                <label for="sp-mode">Darstellung</label>
                <select id="sp-mode" name="displayMode">
                  <option value="cards">Sponsoren-Karten (Logo, Name, Text)</option>
                  <option value="logos">Logo-Wand (nur Logos)</option>
                  <option value="band">Logo-Leiste (kompakt)</option>
                </select>
              </div>
              <div class="field">
                <label for="sp-title">Überschrift</label>
                <input id="sp-title" name="title" type="text" placeholder="Unsere Sponsoren">
              </div>
            </div>
            <div class="field">
              <label for="sp-subtitle">Untertitel</label>
              <textarea id="sp-subtitle" name="subtitle" placeholder="Optionaler Einleitungstext"></textarea>
            </div>
            <label class="perm-item"><input type="checkbox" name="tiersEnabled"><span>Premium-Stufen nutzen (Premium-Sponsoren größer/oben — sonst alle gleich)</span></label>
            <label class="perm-item"><input type="checkbox" name="showHome"><span>Auf der Startseite zeigen</span></label>
            <label class="perm-item"><input type="checkbox" name="showPage"><span>Eigene Sponsoren-Seite verlinken (Menü)</span></label>
            <label class="perm-item"><input type="checkbox" name="showFooter"><span>Logo-Leiste im Footer zeigen (alle Seiten)</span></label>
            <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:8px">
              <button type="submit" class="btn btn--primary"><span class="spinner" aria-hidden="true"></span>Einstellungen speichern</button>
            </div>
            <div class="form-status" role="status" aria-live="polite"></div>
          </form>

          <div id="sponsors-list" class="adm-roles"></div>

          <form id="sponsor-form" class="sub-form" novalidate>
            <input type="hidden" name="id">
            <h3 id="sponsor-form-title" style="font-size:1.1rem;margin-bottom:14px">Neuer Sponsor</h3>
            <div class="field-row">
              <div class="field">
                <label for="s-name">Name <span class="req">*</span></label>
                <input id="s-name" name="name" type="text" placeholder="z. B. Musterbau GmbH">
                <p class="field__error"></p>
              </div>
              <div class="field">
                <label for="s-tier">Stufe</label>
                <select id="s-tier" name="tier">
                  <option value="standard">Standard</option>
                  <option value="premium">Premium</option>
                </select>
              </div>
            </div>
            <div class="field-row">
              <div class="field">
                <label for="s-url">Website</label>
                <input id="s-url" name="url" type="text" placeholder="z. B. musterbau.de">
              </div>
              <div class="field">
                <label for="s-order">Reihenfolge</label>
                <input id="s-order" name="order" type="number" step="1" value="0">
              </div>
            </div>
            <div class="field">
              <label for="s-desc">Beschreibung <span style="font-weight:400;color:var(--text-soft)">(optional, in Karten-Ansicht)</span></label>
              <textarea id="s-desc" name="description" placeholder="Kurzer Text zum Partner"></textarea>
            </div>
            <div class="field" data-sponsor-logo-field>
              <label for="s-logo">Logo <span style="font-weight:400;color:var(--text-soft)">(optional)</span></label>
              <div class="photo-input">
                <img id="s-logo-preview" class="photo-input__preview photo-input__preview--wide" alt="" hidden>
                <div class="photo-input__ph photo-input__ph--wide" id="s-logo-ph" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="5" width="18" height="14" rx="2"/><circle cx="9" cy="11" r="2"/><path d="M21 17l-5-5-4 4-2-2-4 4"/></svg>
                </div>
                <div>
                  <input id="s-logo" name="logo" type="file" accept="image/*">
                  <p style="color:var(--text-soft);font-size:.82rem;margin-top:6px">JPG/PNG, wird automatisch verkleinert.</p>
                  <button type="button" id="s-logo-clear" class="btn btn--outline btn--sm" style="margin-top:8px" hidden>Logo entfernen</button>
                </div>
              </div>
              <p class="field__error"></p>
            </div>
            <div style="display:flex;gap:12px;flex-wrap:wrap">
              <button type="submit" class="btn btn--primary"><span class="spinner" aria-hidden="true"></span>Speichern</button>
              <button type="button" id="sponsor-reset" class="btn btn--outline" hidden>Abbrechen</button>
            </div>
            <div class="form-status" role="status" aria-live="polite"></div>
          </form>
        </div>
      </div>
    </div>
  </section>

  <Fragment slot="scripts">
    <script is:inline src="assets/js/redaktion.js"></script>
  </Fragment>
</Base>
