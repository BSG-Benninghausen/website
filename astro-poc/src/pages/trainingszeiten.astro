---
import Base from "../layouts/Base.astro";
import club from "../data/club.json";
const mapsUrl = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(`${club.street} ${club.city}`)}`;
---
<Base pageTitle="Trainingszeiten">
  <section class="page-hero">
    <img class="page-hero__pattern" src="assets/img/hero-pattern.svg" alt="" aria-hidden="true">
    <img class="page-hero__dragon" src="assets/img/drache-light.png" alt="" aria-hidden="true">
    <div class="wrap page-hero__inner">
      <p class="crumbs"><a href="index.html">Start</a> · Trainingszeiten</p>
      <span class="eyebrow eyebrow--invert">Wann &amp; wo</span>
      <h1>Trainingszeiten</h1>
      <p>Wir trainieren mittwochs und freitags in der {club.venue}. Finde die Gruppe, die zu dir passt.</p>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="section-head">
        <span class="eyebrow">Unsere Gruppen</span>
        <h2>Drei Trainingsgruppen</h2>
        <p>Die Zeiten gelten an unseren Trainingstagen (Mi/Fr). Komm bitte ein paar Minuten früher.</p>
      </div>
      <div class="schedule" data-training>
        <div class="skeleton"></div><div class="skeleton"></div><div class="skeleton"></div>
      </div>
      <div class="notice notice--mock" style="margin-top:26px">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 8v5M12 16h.01"/></svg>
        <p>In den Schulferien und an Feiertagen kann das Training entfallen. Aktuelle Termine findest du im <a href="kalender.html">Kalender</a>.</p>
      </div>
    </div>
  </section>

  <section class="section section--sand">
    <div class="wrap split">
      <div class="reveal">
        <span class="eyebrow">So findest du uns</span>
        <h2>Trainingsort</h2>
        <ul class="info-list" style="margin-top:24px">
          <li>
            <span class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 21s-7-6.5-7-11a7 7 0 0 1 14 0c0 4.5-7 11-7 11z"/><circle cx="12" cy="10" r="2.5"/></svg></span>
            <div><b>{club.venue}</b><span>{club.street}, {club.city}</span></div>
          </li>
          <li>
            <span class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg></span>
            <div><b>Trainingstage</b><span>Mittwochs &amp; freitags</span></div>
          </li>
          <li>
            <span class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h10"/></svg></span>
            <div><b>Was mitbringen?</b><span>Bequeme Sportkleidung, Getränk und gute Laune. Einen Judo-Anzug (Gi) brauchst du fürs Probetraining noch nicht.</span></div>
          </li>
        </ul>
        <a href="anmeldung.html" class="btn btn--primary" style="margin-top:8px">Zum Probetraining anmelden</a>
      </div>
      <div class="split__media reveal">
        <div class="media-frame">
          <a href={mapsUrl} target="_blank" rel="noopener" class="photo-slot" style="position:absolute;inset:0;padding:24px;text-decoration:none">
            <svg viewBox="0 0 24 24" width="56" height="56" fill="none" stroke="#f6c453" stroke-width="2" aria-hidden="true"><path d="M12 21s-7-6.5-7-11a7 7 0 0 1 14 0c0 4.5-7 11-7 11z"/><circle cx="12" cy="10" r="2.5"/></svg>
            <span>{club.street}, {club.city}<br>Auf Google Maps öffnen</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <Fragment slot="scripts">
    <script is:inline src="/assets/js/trainingszeiten.js"></script>
    <script is:inline src="/assets/js/sponsors.js"></script>
  </Fragment>
</Base>
