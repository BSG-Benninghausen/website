---
import Base from "../layouts/Base.astro";
---
<Base pageTitle="Seite nicht gefunden" noindex={true}>
  <section class="hero" style="min-height:70vh;display:flex;align-items:center">
    <img class="hero__pattern" src="assets/img/hero-pattern.svg" alt="" aria-hidden="true">
    <span class="hero__glow hero__glow--a" aria-hidden="true"></span>
    <span class="hero__dragon" aria-hidden="true"></span>
    <div class="wrap center" style="max-width:620px">
      <span class="eyebrow eyebrow--invert" style="justify-content:center">Fehler 404</span>
      <h1 style="font-size:clamp(2.4rem,8vw,4.5rem);color:#fff;margin:14px 0 12px">Ippon verfehlt!</h1>
      <p class="hero__lead" style="margin-inline:auto">Diese Seite konnten wir leider nicht finden. Vielleicht hilft dir einer dieser Wege weiter:</p>
      <div class="hero__cta" style="justify-content:center">
        <a href="index.html" class="btn btn--gold btn--lg">Zur Startseite</a>
        <a href="trainingszeiten.html" class="btn btn--ghost btn--lg">Trainingszeiten</a>
        <a href="kontakt.html" class="btn btn--ghost btn--lg">Kontakt</a>
      </div>
    </div>
  </section>
</Base>
