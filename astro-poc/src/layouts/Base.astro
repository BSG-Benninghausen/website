---
/* =====================================================================
   Base.astro – EINE branding-neutrale Layout-Komponente für alle Seiten.
   Ersetzt die ~100 Zeilen head+nav+footer, die früher in JEDER *.html
   dupliziert waren. Alles Vereins-/Layout-Spezifische kommt zur BUILD-ZEIT
   aus der aktiven Club-Config (assets/data/club.<id>.json, aufgelöst über
   active-club.mjs / BSG_CLUB_ID) – kein hartcodiertes Branding im geteilten
   Markup. Eine andere Marke = nur club.<id>.json (+ Theme + Seeds + Bilder)
   tauschen und BSG_CLUB_ID setzen, ohne diese Datei anzufassen.

   Level-2 „config-gesteuertes Layout": Navigation, Footer-Spalten, Socials,
   CTA und der dekorative Akzent-Balken werden aus Daten gerendert. Schnell
   wechselnde Inhalte (data-site-Texte, News, Termine) bleiben dynamisch über
   dieselben Vanilla-JS-Skripte.
   ===================================================================== */
import { loadClub } from "../active-club.mjs";
const club = loadClub();

interface Props {
  pageTitle?: string;
  description?: string;
  noindex?: boolean;
}
const { pageTitle = "", description = club.description, noindex = false } = Astro.props;
const title = pageTitle ? `${pageTitle} – ${club.name}` : `${club.name} – ${club.tagline}`;
const logo = club.logo;
const favicon = club.favicon || "assets/img/favicon.png";
const appleIcon = club.apple_touch_icon || "assets/img/apple-touch-icon.png";
const year = new Date().getFullYear();

const nav = club.nav || [];
const footerColumns = club.footer_columns || [];
const socials = club.socials || [];
const cta = club.cta || null;

/* Optionale API-Anbindung an ein echtes Backend (config-gesteuert via club.api).
   Ohne club.api.base bleibt alles im Mock (z. B. der Musterverein-Demo-Build);
   ist eine Base gesetzt, läuft die Produktion im Hybrid-Modus (live-Routes ans
   echte Backend), lokal/Dev weiter im Mock.
   Build-Env übersteuert den Deploy-Default (z. B. für einen same-origin-Prod-
   Deploy): BSG_API_MODE=real schaltet ALLE /api/* aufs echte Backend, BSG_API_BASE
   setzt die Backend-URL ("" = same-origin /api). Ungesetzt = bisheriges Verhalten,
   der Pages-Build bleibt damit unverändert. */
const apiMode = (process.env.BSG_API_MODE || "").trim();
const apiBaseRaw = process.env.BSG_API_BASE !== undefined
  ? process.env.BSG_API_BASE
  : ((club.api && club.api.base) || "");
// Whitespace + abschließende Slashes entfernen, damit base + "/api/…" nicht zu
// " /api/…" oder "…//api/…" wird (z. B. bei kopierten Secrets/Env-Werten).
const apiBase = apiBaseRaw.trim().replace(/\/+$/, "");
const apiLive = (club.api && club.api.authLive) || [];

/* Social-Icons (inline-SVG-Pfade je Typ) – generisch, ohne club-spezifisches Markup. */
const SOCIAL_ICONS = {
  instagram:
    '<rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>',
  facebook:
    '<path d="M14 9h3V5h-3a4 4 0 0 0-4 4v2H7v4h3v6h4v-6h3l1-4h-4V9a1 1 0 0 1 1-1z"/>',
  youtube:
    '<rect x="2" y="5" width="20" height="14" rx="4"/><path d="M10 9l5 3-5 3z" fill="currentColor" stroke="none"/>',
  link: '<path d="M10 13a5 5 0 0 0 7 0l2-2a5 5 0 0 0-7-7l-1 1"/><path d="M14 11a5 5 0 0 0-7 0l-2 2a5 5 0 0 0 7 7l1-1"/>',
};
const iconFor = (type) => SOCIAL_ICONS[type] || SOCIAL_ICONS.link;
---
<!DOCTYPE html>
<html lang="de" data-club-site>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex" />}
  <link rel="icon" type="image/png" href={favicon} />
  <link rel="apple-touch-icon" href={appleIcon} />
  <meta name="theme-color" content={club.theme_color} />
  <link rel="manifest" href="manifest.webmanifest" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content={club.short_name} />
  <meta name="mobile-web-app-capable" content="yes" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Sora:wght@600;700&display=swap" rel="stylesheet" />
  <!-- window.BSG_CLUB + window.BSG_API zur Build-Zeit aus der aktiven Club-Config
       (mock-api.js / api-config.js lesen sie). Ersetzt das Laufzeit-club-config.js
       für den Single-Tenant-Build; ns/Seed/Admin/Theme/api stammen aus
       assets/data/club.<id>.json – Single Source of Truth. -->
  <script is:inline set:html={`
window.BSG_CLUB={id:${JSON.stringify(club.id)},name:${JSON.stringify(club.name)},clubSeed:${JSON.stringify(club.clubSeed)},ns:${JSON.stringify(club.ns)}};
window.BSG_ADMIN_EMAIL=${JSON.stringify(club.admin_email)};
(function(){
  var MODE=${JSON.stringify(apiMode)};
  var BASE=${JSON.stringify(apiBase)};
  var LIVE=${JSON.stringify(apiLive)};
  var h=(location.hostname||"").toLowerCase();
  var dev=location.protocol==="file:"||h==="localhost"||h==="127.0.0.1"||h==="";
  if(dev){window.BSG_API={mode:"mock",base:"",live:[]};}
  else if(MODE==="real"){window.BSG_API={mode:"real",base:BASE,live:[]};}
  else if(MODE==="hybrid"||BASE){window.BSG_API={mode:"hybrid",base:BASE,live:LIVE};}
  else{window.BSG_API={mode:"mock",base:"",live:[]};}
})();
`}></script>
  <link rel="stylesheet" href={club.theme_css} />
  <link rel="stylesheet" href="assets/css/styles.css" />
</head>
<body>
  <a class="skip-link" href="#main">Zum Inhalt springen</a>

  <header class="site-header">
    {club.header_accent_bar && (
      <div class="belt-bar" aria-hidden="true"><span></span><span></span><span></span><span></span><span></span></div>
    )}
    <nav class="nav wrap" aria-label="Hauptnavigation">
      <a href="index.html" class="brand" aria-label="Zur Startseite">
        <img class="brand__logo" src={logo} alt="" width="42" height="42" />
        <span class="brand__name"><span>{club.brand_name}</span><small>{club.brand_sub}</small></span>
      </a>
      <button class="nav__toggle" aria-expanded="false" aria-controls="nav-menu" aria-label="Menü öffnen"><span></span></button>
      <div class="nav__menu" id="nav-menu">
        <ul class="nav__links">
          {nav.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
        </ul>

        <div class="nav__account">
          <a href="login.html" class="nav__login" data-account-link>Login</a>
          <div class="nav__user" data-account-menu hidden>
            <button type="button" class="nav__user-btn" aria-haspopup="true" aria-expanded="false" aria-controls="account-menu">
              <span class="nav__avatar" data-account-avatar aria-hidden="true"></span>
              <span class="nav__user-name" data-account-name>Mein Konto</span>
              <svg class="nav__chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
            </button>
            <ul class="nav__dropdown" id="account-menu" role="menu">
              <li role="none" class="nav__dropdown-head" data-account-head hidden>
                <strong data-account-fullname></strong>
                <span data-account-email></span>
              </li>
              <li role="none"><a role="menuitem" href="konto.html">Mein Konto</a></li>
              <li role="none"><a role="menuitem" href="mitglieder.html" data-members-link hidden>Mitglieder &amp; Benutzer</a></li>
              <li role="none"><a role="menuitem" href="redaktion.html" data-redaktion-link hidden>Redaktion</a></li>
              <li role="none"><a role="menuitem" href="admin.html" data-admin-link hidden>Admin</a></li>
              <li role="none" class="nav__dropdown-sep"><button type="button" role="menuitem" class="nav__logout" data-logout>Abmelden</button></li>
            </ul>
          </div>
        </div>
        {cta && <div class="nav__cta"><a href={cta.href} class="btn btn--primary">{cta.label}</a></div>}
      </div>
    </nav>
  </header>

  <main id="main"><slot /></main>

  <footer class="site-footer">
    <div class="wrap">
      <div class="footer-grid">
        <div class="footer-about">
          <a href="index.html" class="brand">
            <img class="brand__logo" src={logo} alt="" width="42" height="42" />
            <span class="brand__name"><span>{club.brand_name}</span><small>{club.brand_sub}</small></span>
          </a>
          <p>{club.description}</p>
          <div class="socials">
            {socials.map((s) => (
              <a href={s.url} aria-label={s.type} target="_blank" rel="noopener">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" set:html={iconFor(s.type)}></svg>
              </a>
            ))}
          </div>
        </div>
        {footerColumns.map((col) => (
          <div class="footer-col">
            <h4>{col.title}</h4>
            <ul>
              {col.items.map((it) => <li><a href={it.href}>{it.label}</a></li>)}
            </ul>
          </div>
        ))}
        <div class="footer-col">
          <h4>Training</h4>
          <ul>
            <li>{club.venue}</li>
            <li>{club.street}, {club.city}</li>
            {club.training_days && <li>{club.training_days}</li>}
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <span>© {year} {club.name} · {club.sport} in {club.locality}</span>
        <span><a href="kontakt.html">Impressum</a> · <a href="datenschutz.html">Datenschutz</a></span>
      </div>
    </div>
  </footer>

  <script is:inline src="assets/js/api-config.js"></script>
  <script is:inline src="assets/js/mock-api.js"></script>
  <script is:inline src="assets/js/main.js"></script>
  <!-- Global: Sponsoren-Funktion (Footer-Logo-Leiste + Menü-Link) auf JEDER Seite.
       Komplett config-gesteuert (/api/sponsors-config); aus = passiert nichts. -->
  <script is:inline src="assets/js/sponsors.js"></script>
  <!-- Global: Webshop-Menülink (nur eingeloggt, config-gesteuert via /api/shop-config).
       Aus oder ausgeloggt = kein Link. Der Katalog/Checkout läuft nur auf shop.html. -->
  <script is:inline src="assets/js/shop.js"></script>
  <slot name="scripts" />
</body>
</html>
